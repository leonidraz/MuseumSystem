<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.transform.Scale?>

<BorderPane prefHeight="888.0" prefWidth="1920.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.museumcatalog.Controllers.MainFormController">
    <padding>
        <Insets left="40.0" right="40.0" />
    </padding>

    <left>
        <VBox prefHeight="490.0" prefWidth="605.0" spacing="20.0" style="-fx-background-color: #EBEFF0; -fx-background-radius: 10px; -fx-padding: 25px;">
            <children>
                <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="50.0" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Быстрый доступ">
                    <VBox.margin><Insets /></VBox.margin>
                </Label>

                <Button fx:id="btnRegisterExhibit" mnemonicParsing="false" prefHeight="100.0" prefWidth="545.0" styleClass="quick-access-button" text="Зарегистрировать предмет">
                    <VBox.margin><Insets left="10.0" /></VBox.margin>
                </Button>

                <Button fx:id="btnRegisterOwner" mnemonicParsing="false" prefHeight="100.0" prefWidth="545.0" styleClass="quick-access-button" text="Зарегистрировать владельца">
                    <VBox.margin><Insets left="10.0" /></VBox.margin>
                </Button>

                <Button fx:id="btnCreateDocument" mnemonicParsing="false" prefHeight="100.0" prefWidth="695.0" styleClass="quick-access-button" text="Создать документ">
                    <VBox.margin><Insets left="10.0" /></VBox.margin>
                </Button>
                <Button fx:id="btnAddEmployee" mnemonicParsing="false" prefHeight="100.0" prefWidth="1055.0" styleClass="quick-access-button" text="Добавить сотрудника">
                    <VBox.margin>
                        <Insets left="10.0" />
                    </VBox.margin>
                </Button>
            </children>
            <BorderPane.margin><Insets left="20.0" /></BorderPane.margin>
        </VBox>
    </left>

    <center>
        <VBox prefHeight="286.0" prefWidth="1212.0" style="-fx-background-color: #EBEFF0; -fx-background-radius: 10px; -fx-padding: 30px;">
            <children>
                <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="50.0" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Статистика системы">
                    <VBox.margin><Insets bottom="25.0" /></VBox.margin>
                </Label>

                <HBox prefHeight="299.0" prefWidth="1200.0" spacing="25.0" style="-fx-alignment: CENTER;">
                    <VBox alignment="CENTER" prefHeight="168.0" prefWidth="200.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 28px; -fx-min-width: 210px; -fx-max-width: 250px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
                        <Label fx:id="processedCountLabel" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #607D8B;" text="124" />
                        <Label prefHeight="30.0" prefWidth="118.0" style="-fx-font-size: 20px; -fx-text-fill: #555555;" text="В обработке" />
                    </VBox>

                    <VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 28px; -fx-min-width: 210px; -fx-max-width: 250px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
                        <Label fx:id="inFundsCountLabel" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #00BCD4;" text="37" />
                        <Label prefHeight="28.0" prefWidth="90.0" style="-fx-font-size: 20px; -fx-text-fill: #555555;" text="В фондах" />
                    </VBox>
                    <VBox alignment="CENTER" minWidth="162.0" prefHeight="179.0" prefWidth="162.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 28px; -fx-min-width: 210px; -fx-max-width: 250px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
                        <children>
                            <Label fx:id="exhibitionsCountLabel" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #FF5722;" text="7" />
                            <Label prefHeight="30.0" prefWidth="124.0" style="-fx-font-size: 20px; -fx-text-fill: #555555;" text="На выставках" />
                        </children>
                    </VBox>

                    <VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 28px; -fx-min-width: 210px; -fx-max-width: 250px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
                        <Label fx:id="employeesCountLabel" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;" text="24" />
                        <Label style="-fx-font-size: 20px; -fx-text-fill: #555555;" text="Сотрудников" />
                    </VBox>

                    <VBox alignment="CENTER" prefHeight="93.0" prefWidth="220.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 28px; -fx-min-width: 210px; -fx-max-width: 250px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
                        <Label fx:id="ownersCountLabel" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #C7923E;" text="8" />
                        <Label style="-fx-font-size: 20px; -fx-text-fill: #555555;" text="Владельцев" />
                    </VBox>

                    <VBox.margin><Insets bottom="50.0" /></VBox.margin>
                </HBox>
            </children>
            <BorderPane.margin><Insets left="25.0" right="25.0" /></BorderPane.margin>
        </VBox>
    </center>

    <bottom>
        <VBox prefHeight="447.0" prefWidth="1885.0" style="-fx-background-color: #EBEFF0; -fx-background-radius: 10px; -fx-padding: 30px;">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" prefHeight="415.0" prefWidth="1770.0" vbarPolicy="NEVER">
                    <content>
                        <HBox fx:id="exhibitsContainer" prefWidth="2065.0" spacing="25.0" style="-fx-padding: 10px;">

                        </HBox>
                    </content>
                </ScrollPane>
            </children>
            <BorderPane.margin><Insets bottom="35.0" left="25.0" right="25.0" top="20.0" /></BorderPane.margin>
        </VBox>
    </bottom>

</BorderPane>