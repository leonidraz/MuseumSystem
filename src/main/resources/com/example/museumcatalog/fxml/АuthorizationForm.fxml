<AnchorPane maxHeight="500.0" maxWidth="450.0" minHeight="500.0" minWidth="450.0" prefHeight="550.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.museumcatalog.Controllers.AuthorizationFormController">
   <children>
      <AnchorPane prefHeight="116.0" prefWidth="450.0" style="-fx-background-color: #7CB4CF;">
         <children>
            <Label layoutX="144.0" layoutY="39.0" text="Авторизация" textFill="WHITE">
               <font>
                  <Font size="27.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <GridPane alignment="CENTER" layoutX="59.0" layoutY="160.0" prefHeight="272.0" prefWidth="332.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="332.0" minWidth="10.0" prefWidth="325.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" GridPane.rowIndex="5">
               <children>
                  <Button fx:id="enterBtn" mnemonicParsing="false" prefHeight="44.0" prefWidth="207.0" style="-fx-background-color: #7CB4CF;" text="Войти" textAlignment="CENTER" textFill="WHITE">
                     <font>
                        <Font size="17.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <Label prefHeight="17.0" prefWidth="406.0" text="Логин">
