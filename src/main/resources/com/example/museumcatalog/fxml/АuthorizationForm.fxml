            </Label>
            <Label prefHeight="17.0" prefWidth="406.0" text="Пароль" GridPane.rowIndex="2">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <TextField fx:id="loginTF" prefHeight="52.0" prefWidth="332.0" promptText="admin" GridPane.rowIndex="1">
               <font>
                  <Font size="18.0" />
               </font>
            </TextField>
            <PasswordField fx:id="passwordTF" prefHeight="60.0" prefWidth="332.0" promptText="*******" GridPane.rowIndex="3">
               <font>
                  <Font size="18.0" />
               </font>
            </PasswordField>
         </children>
      </GridPane>
   </children>
</AnchorPane>
